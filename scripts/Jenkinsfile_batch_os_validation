#!groovy

node {
  def branch = "main"
  def test_dir = "${env.TEST_DIRECTORY_LIST}".split(',')

  if ("${env.BRANCH}" != "null" && "${env.BRANCH}" != "") {
    branch = "${env.BRANCH}"
  }

  def repo = scm.userRemoteConfigs
  if ("${env.REPO}" != "null" && "${env.REPO}" != "") {
    repo = [
      [url: "${env.REPO}"]
    ]
  }
  def timeout = "60m"
  if ("${env.TIMEOUT}" != "null" && "${env.TIMEOUT}" != "") {
    timeout = "${env.TIMEOUT}"
  }

  def splitAndNormalize = { String wholeString ->
    return (wholeString ?: '')
      .split(/[\s,]+/)
      .collect { it.trim() }
      .findAll { it }
  }

  wrap([$class: 'AnsiColorBuildWrapper', 'colorMapName': 'XTerm', 'defaultFg': 2, 'defaultBg': 1]) {
    withFolderProperties {
      paramsMap = []
      params.each {
        if (it.value && it.value.trim() != "") {
          paramsMap << "$it.key=$it.value"
        }
      }
      withEnv(paramsMap) {
        stage('Checkout') {
          deleteDir()
          checkout([
            $class: 'GitSCM',
            branches: [
              [name: "*/${branch}"]
            ],
            extensions: scm.extensions + [
              [$class: 'CleanCheckout']
            ],
            userRemoteConfigs: repo
          ])
        }
        dir("./") {
          stage('Run Parallel Jobs') {
            def installVersions = splitAndNormalize(env.INSTALL_VERSIONS)
            def upgradeVersions = splitAndNormalize(env.UPGRADE_VERSIONS)

            if (installVersions.isEmpty()) {
              error("INSTALL_VERSIONS is empty.")
            }
            if (installVersions.size() != upgradeVersions.size()) {
              error("INSTALL_VERSIONS (${installVersions.size()}) and UPGRADE_VERSIONS (${upgradeVersions.size()}) must have the same number of entries.")
            }

            def product_name = "${env.PRODUCT_NAME}"
            def suffix = (product_name == "rke2") ? "_rpm" : ""
            def testToJobMap = [
              "validatecluster": "${product_name}_validate_cluster",
              "validatecluster_arm": "${product_name}_validate_cluster_arm",
              "conformance": "${product_name}_conformance",
              "upgradesuc": "${product_name}_suc_upgrade${suffix}",
              "upgradesuc_arm": "${product_name}_suc_upgrade_arm",
              "deployrancher": "${product_name}_deploy_rancher_prime_release",
              "clusterrestore": "${product_name}_cluster_restore",
              "externaldb": "${product_name}_external_datastore",
              "mixedoscluster": "rke2_windows_agent"
            ]

            def jobs = [:]

            installVersions.eachWithIndex { installVersion, idx ->
              def upgradeVersion = upgradeVersions[idx]

              echo "Planning tests for version pair: install=${installVersion} upgrade=${upgradeVersion}"

              test_dir.each { test_name ->
                def actual_testdir_name = test_name
                def job_test_args = null
                def job_aws_ssh_key_name = "${AWS_SSH_KEY_NAME}"
                def job_aws_ssh_pem_key = "${AWS_SSH_PEM_KEY}"

                if (test_name.contains("validatecluster")) {
                  actual_testdir_name = "validatecluster"
                }

                if (test_name.contains("upgradesuc")) {
                  actual_testdir_name = "upgradecluster"
                  job_test_args = "${TEST_ARGS} -tags=upgradesuc -sucUpgradeVersion ${upgradeVersion} -channel ${UPGRADE_CHANNEL}"
                }

                if (test_name.contains("deployrancher")) {
                  actual_testdir_name = "deployrancher"
                }

                if (test_name.contains("externaldb")) {
                  actual_testdir_name = "validatecluster"
                }

                if (test_name.contains("mixedoscluster")) {
                  actual_testdir_name = "mixedoscluster"
                }

                def os_validation_params = [
                  string(name: 'REPO', value: "${REPO}"),
                  string(name: 'BRANCH', value: "${BRANCH}"),
                  string(name: 'PRODUCT_NAME', value: "${PRODUCT_NAME}"),
                  string(name: 'INSTALL_VERSION', value: installVersion),
                  string(name: 'UPGRADE_VERSION', value: upgradeVersion),
                  string(name: 'INSTALL_MODE', value: "${INSTALL_MODE}"),
                  string(name: 'INSTALL_CHANNEL', value: "${INSTALL_CHANNEL}"),
                  string(name: 'UPGRADE_CHANNEL', value: "${UPGRADE_CHANNEL}"),
                  string(name: 'HOSTNAME_PREFIX', value: "${HOSTNAME_PREFIX}"),
                  string(name: 'TEST_DIRECTORY', value: actual_testdir_name),
                  string(name: 'BATCH_OS_AWS_AMI', value: "${AWS_AMI}"),
                  string(name: 'BATCH_OS_AWS_USER', value: "${AWS_USER}"),
                  string(name: 'BATCH_OS_NODE_OS', value: "${NODE_OS}"),
                  string(name: 'AWS_SSH_KEY_NAME', value: job_aws_ssh_key_name),
                  string(name: 'AWS_SSH_PEM_KEY', value: job_aws_ssh_pem_key),
                  string(name: 'REPORT_TO_QASE', value: "${REPORT_TO_QASE}"),
                  string(name: 'QASE_PROJECT_ID', value: "${QASE_PROJECT_ID}"),
                  string(name: 'QASE_RUN_ID', value: "${QASE_RUN_ID}"),
                ]

                if (job_test_args != null) {
                  os_validation_params.add(0, string(name: 'TEST_ARGS', value: job_test_args))
                }

                def jobName = testToJobMap[test_name]
                def jobKey = "${test_name} | ${installVersion}"

                if (jobName) {
                  jobs[jobKey] = { build job: jobName, parameters: os_validation_params }
                }
              } // for each test_dir loop
            } // for each version pair

            echo "Planned ${jobs.size()} total jobs across ${installVersions.size()} version(s) and ${test_dir.size()} test(s)"
            parallel jobs
          } // stage run parallel jobs
        } // dir
      } // withEnv
    } // withFolderProperties
  } // wrap
} // node
